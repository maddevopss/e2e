# MADSuite E2E Environment Example
# Copy this file to .env and configure for your environment
# Never commit .env with real secrets

# Frontend URL
TEST_BASE_URL=http://127.0.0.1:3000

# Backend API URL
TEST_API_URL=http://127.0.0.1:5000/api

# PostgreSQL for E2E tests (isolated from development/production)
# Example: postgresql://postgres:postgres@127.0.0.1:5433/madsuite_e2e
E2E_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/madsuite_e2e

# Storage state file for authenticated sessions (generated by tests)
E2E_AUTH_FILE=storageState/auth.json

# Playwright configuration
TEST_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
