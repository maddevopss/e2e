# MADSuite E2E Environment Example

# Frontend MADSuite à tester
TEST_BASE_URL=http://localhost:3000

# Backend MADSuite, utilisé par les helpers de seed/auth lorsque disponibles
TEST_API_URL=http://localhost:5000/api

# Compte de test seulement. Ne jamais utiliser un compte réel ou client.
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_PASSWORD=change-me

# Optionnel : fichier storageState généré pour une session de test
E2E_AUTH_FILE=storageState/auth.json

TEST_HEADLESS=true
